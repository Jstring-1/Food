{
  "name": "food",
  "version": "0.1.0",
  "description": "Food & nutrition database — USDA FoodData Central + Open Food Facts ingestion",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:migrate": "tsx src/migrate.ts",
    "ingest:fdc": "tsx src/ingest/fdc.ts",
    "ingest:off": "tsx src/ingest/off.ts",
    "dedupe:fdc": "tsx src/maintenance/dedupe-fdc.ts",
    "denormalize:fdc": "tsx src/maintenance/run-denormalize.ts",
    "counts": "tsx src/counts.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "duckdb": "^1.4.4",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "pg-copy-streams": "^6.0.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
