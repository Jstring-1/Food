# Railway gives you this on the Postgres service → "Connect" tab.
# Use the public/proxy URL when ingesting from your laptop; the internal
# *.railway.internal URL only resolves from inside Railway.
DATABASE_URL=postgres://user:pass@host:port/dbname

# Railway external connections require SSL. Set to "require" when using the
# public proxy URL; leave unset when running inside Railway.
PGSSL=require

# USDA FoodData Central API key — only needed for LIVE lookups against
# api.nal.usda.gov, not for the bulk dump ingestion. Get one free at
# https://fdc.nal.usda.gov/api-key-signup
USDA_API_TOKEN=

# Local paths to the downloaded dumps (see README in chat).
# FDC: extracted folder containing food.csv, nutrient.csv, etc.
FDC_DIR=./data/fdc
# OFF: the Parquet export (food.parquet).
OFF_FILE=./data/food.parquet
# Set to 1 to also store the full per-nutrient JSON blob (~8 GB across the dump).
# Off by default; the common macros are flattened into columns regardless.
OFF_NUTRIMENTS_JSON=0
